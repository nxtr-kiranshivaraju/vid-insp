{
  "name": "vid-insp-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n ui,compiler-stub,runtime-stub -c green,blue,magenta \"next dev -p 3000\" \"tsx stubs/compiler-stub.ts\" \"tsx stubs/runtime-stub.ts\"",
    "dev:ui": "next dev -p 3000",
    "dev:compiler-stub": "tsx stubs/compiler-stub.ts",
    "dev:runtime-stub": "tsx stubs/runtime-stub.ts",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.2.5",
    "zod": "3.23.8",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4",
    "class-variance-authority": "0.7.1",
    "lucide-react": "0.460.0",
    "yaml": "2.6.1",
    "express": "4.21.1",
    "cors": "2.8.5"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "typescript": "5.6.3",
    "tailwindcss": "3.4.14",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tsx": "4.19.2",
    "concurrently": "9.1.0",
    "@playwright/test": "1.48.2",
    "vitest": "2.1.5",
    "@vitest/ui": "2.1.5",
    "msw": "2.6.5",
    "jsdom": "25.0.1",
    "@types/jsdom": "21.1.7",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18"
  }
}
