# Compiler service base URL (Issue 2 or stub)
COMPILER_URL=http://localhost:8001

# Runtime service base URL (Issue 3 or stub)
RUNTIME_URL=http://localhost:8002

# Bearer token required for all UI requests. Single-tenant, single user.
AUTH_TOKEN=dev-token

# Public-facing copies (read by browser code through next.config or via /api/config).
NEXT_PUBLIC_COMPILER_URL=http://localhost:8001
NEXT_PUBLIC_RUNTIME_URL=http://localhost:8002
