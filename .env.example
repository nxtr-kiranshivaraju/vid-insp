# Copy to .env and fill in real values before `docker compose up`.

# Stage A — intent extraction (default Anthropic via OpenAI-compat layer)
COMPILER_INTENT_BASE_URL=https://api.anthropic.com/v1
COMPILER_INTENT_API_KEY=
COMPILER_INTENT_MODEL=claude-sonnet-4-6

# Stage C — question generation
COMPILER_PROMPTGEN_BASE_URL=https://api.anthropic.com/v1
COMPILER_PROMPTGEN_API_KEY=
COMPILER_PROMPTGEN_MODEL=claude-opus-4-7
